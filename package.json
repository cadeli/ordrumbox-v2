{
  "name": "minfact",
  "version": "1.0.0",
  "description": "MinFact /online ordrumbox v2.0",
  "main": "electron-main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build && cp sw.js manifest.json dist/ && cp -r assets/data assets/kits assets/images dist/assets/",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.ordrumbox.v2",
    "productName": "orDrumbox",
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "assets/images/logo.png"
    ],
    "directories": {
      "output": "release"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://framagit.org/phr/minfact.git"
  },
  "keywords": [
    "online drum machine",
    "js",
    "vanilla"
  ],
  "author": "orDrumbox team",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "node-web-audio-api": "^2.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "eslint": "^10.4.1",
    "express": "^5.2.1",
    "terser": "^5.46.0"
  }
}
